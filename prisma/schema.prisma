generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── USERS ───────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("STUDENT") // STUDENT | INSTRUCTOR | ADMIN | OVERALL_ADMIN
  approved     Boolean  @default(true) // false for new INSTRUCTOR/ADMIN signups until admin approves
  avatar       String?
  bio          String?

  // Email verification (kept but not enforced)
  emailVerified      Boolean   @default(true)
  verificationToken  String?   @unique
  verificationExpires DateTime?

  // Profile fields
  dateOfBirth String?
  country     String?
  city        String?
  phone       String?
  careerGoal  String?

  // Password reset
  resetToken   String?   @unique
  resetExpires DateTime?

  // Role application
  appliedRole String? // "INSTRUCTOR" or "ADMIN" — pending application

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  courses     Course[]
  enrollments Enrollment[]
  progress    Progress[]
  favorites   Favorite[]
  wishlist    Wishlist[]
  reports     Report[]
  questions   Question[]
  answers     Answer[]
  discussions Discussion[]
  gpaCourses        GpaCourse[]
  uploadedMaterials CourseMaterial[]
  generatedQuizzes  GeneratedQuiz[]
}

// ─── CATEGORIES ──────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  courses Course[]
}

// ─── COURSES ─────────────────────────────────────────

model Course {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  price         Float
  thumbnail     String?
  status        String   @default("DRAFT") // DRAFT | SUBMITTED | APPROVED | PUBLISHED | REJECTED
  rejectionNote String?
  liveClassLink String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  instructorId String
  instructor   User     @relation(fields: [instructorId], references: [id])
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])

  sections         Section[]
  enrollments      Enrollment[]
  favorites        Favorite[]
  wishlist         Wishlist[]
  questions        Question[]
  discussions      Discussion[]
  courseMaterials  CourseMaterial[]
  generatedQuizzes GeneratedQuiz[]
}

// ─── SECTIONS ────────────────────────────────────────

model Section {
  id       String   @id @default(cuid())
  title    String
  order    Int
  courseId  String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
}

// ─── LESSONS ─────────────────────────────────────────

model Lesson {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String
  duration  Int      @default(0) // seconds
  order     Int
  isFree    Boolean  @default(false)
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress  Progress[]
  questions Question[]
}

// ─── ENROLLMENTS ─────────────────────────────────────

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// ─── PROGRESS ────────────────────────────────────────

model Progress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id])

  @@unique([userId, lessonId])
}

// ─── FAVORITES ───────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── WISHLIST ────────────────────────────────────────

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  courseId   String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ─── REPORTS ─────────────────────────────────────────

model Report {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    String   @default("OPEN") // OPEN | REVIEWED | RESOLVED
  adminNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── QUESTIONS ──────────────────────────────────────

model Question {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  lessonId  String?
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson  Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  answers Answer[]
}

// ─── ANSWERS ────────────────────────────────────────

model Answer {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  body       String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ─── DISCUSSIONS ────────────────────────────────────

model Discussion {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  body      String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

// ─── GPA CALCULATOR ────────────────────────────────

model GpaCourse {
  id          String   @id @default(cuid())
  name        String
  year        String   // "Year 1", "Year 2", etc.
  semester    String?  // "Semester 1", "Semester 2", or null
  courseType  String   // "Full" or "Half"
  creditHours Float
  grade       String   // "A+", "A", "B+", "B", "C+", "C", "D+", "D", "F", etc.
  gradePoints Float    // calculated: GRADE_MAP[grade]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AI STUDY MATERIALS ────────────────────────────

model CourseMaterial {
  id            String   @id @default(cuid())
  courseId      String
  title         String
  filename      String
  fileType      String   // "pdf" | "docx" | "txt" | "text"
  extractedText String
  uploadedBy    String
  createdAt     DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
}

// ─── AI GENERATED QUIZZES ──────────────────────────

model GeneratedQuiz {
  id           String   @id @default(cuid())
  courseId     String
  topic        String?
  difficulty   String   @default("medium")
  questionType String   @default("multiple-choice")
  questions    Json     // array of { question, options?, correctAnswer, explanation }
  generatedBy  String
  createdAt    DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [generatedBy], references: [id], onDelete: Cascade)
}
